{
  "name": "luma-theme",
  "displayName": "Luma",
  "description": "A soothing, low-intensity colors theme",
  "author": {
    "name": "Sébastien Cottinet"
  },
  "version": "2.0.2",
  "publisher": "SebastienCottinet",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Themes"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/scottinet/luma.git"
  },
  "homepage": "https://github.com/scottinet/luma#readme",
  "bugs": {
    "url": "https://github.com/scottinet/luma/issues"
  },
  "keywords": [
    "theme",
    "oklab",
    "oklch",
    "calming",
    "soothing"
  ],
  "icon": "assets/icon-128x128.png",
  "contributes": {
    "themes": [
      {
        "label": "Luma - Light",
        "uiTheme": "vs",
        "path": "./themes/editors/vscode/luma-light.json"
      },
      {
        "label": "Luma - Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/editors/vscode/luma-dark.json"
      }
    ]
  },
  "scripts": {
    "build": "tsx src/build.ts",
    "package": "vsce package --readme-path themes/editors/vscode/README.md"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  }
}
